# ===============================
# SOLPLANET
# ===============================
INVERTER_URL=http://YOUR_INVERTER_IP:8484
BATTERY_SN=YOUR_BATTERY_SERIAL

HTTP_TIMEOUT=8
HTTP_RETRIES=3
HTTP_RETRY_DELAY=1

# ===============================
# DATABASE (MySQL/MariaDB)
# ===============================
DB_ENABLED=true
DB_HOST=YOUR_DB_HOST
DB_PORT=3306
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=solplanet_ems
DB_SAVE_HISTORY=true

# ===============================
# MQTT
# ===============================
MQTT_ENABLED=true
MQTT_HOST=YOUR_MQTT_HOST
MQTT_PORT=1883
MQTT_USER=YOUR_MQTT_USER
MQTT_PASSWORD=YOUR_MQTT_PASSWORD
MQTT_CLIENT_ID=solplanet-ems
MQTT_KEEPALIVE=60
MQTT_QOS=1

MQTT_TOPIC_STATE=solplanet/estado
MQTT_TOPIC_CMD=solplanet/comando
MQTT_TOPIC_DEBUG=solplanet/debug
MQTT_TOPIC_AVAILABILITY=solplanet/disponibilidad

# ===============================
# SISTEMA
# ===============================
POLL_INTERVAL=10
SAVE_INTERVAL=5
LOG_LEVEL=INFO
PUBLISH_DEBUG_EVERY_CYCLE=false
